# `--install-links=true` forces npm to physically copy `file:` workspace
# deps into node_modules instead of symlinking. This is required because:
#
# 1. Metro on Expo SDK 54 cannot reliably follow symlinks for nested-route
#    imports (verified May 2026 — bundle fails with "Unable to resolve
#    @otf/ui-native from app/...").
# 2. Once `@otf/ui-native` is a real dir at node_modules/@otf/ui-native/,
#    npm correctly auto-installs its peerDependencies (tamagui,
#    @tamagui/config, @tamagui/core). With symlinks, those peers don't
#    auto-install — bundle then fails on `@tamagui/config/v5`.
#
# `scripts/install-workspace-deps.sh` does the same thing as a shell
# rsync, but adding it here as an npm config makes plain `npm install`
# Just Work without remembering the flag.
install-links=true
