# Match the the SDK showcase setup — flat node_modules so Metro
# can resolve transitive Expo + RN deps the way npm/yarn would.
# Without this, pnpm leaves @react-navigation/*, @babel/runtime,
# @react-native/normalize-colors, expo-modules-core etc inside .pnpm/<hash>
# which Expo's default Metro resolver can't see.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=*
