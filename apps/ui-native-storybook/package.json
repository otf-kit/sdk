{
  "name": "otf-ui-native-storybook",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 npx expo start --web --port 3010",
    "dev:native": "EXPO_NO_TELEMETRY=1 npx expo start",
    "build:web": "EXPO_NO_TELEMETRY=1 npx expo export --platform web --output-dir dist",
    "deploy": "set -a && . ../../.env && set +a && npm run build:web && npx wrangler pages deploy dist --project-name otf-ui-native-storybook --commit-dirty=true",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@otf/ui-native": "file:../../packages/ui-native",
    "@otf/tokens": "file:../../packages/tokens",
    "@tamagui/lucide-icons": "^1.144.4",
    "@tamagui/portal": "^1.144.4",
    "expo": "~54.0.25",
    "expo-font": "~14.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.9",
    "expo-router": "~6.0.15",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  }
}
