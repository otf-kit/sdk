{
  "name": "@otf/ui-native-storybook",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start --web --port 3010",
    "dev:native": "EXPO_NO_TELEMETRY=1 expo start",
    "build": "EXPO_NO_TELEMETRY=1 expo export --platform web --output-dir dist",
    "preview": "npx serve dist",
    "deploy": "set -a && . ../../.env && set +a && bun run build && npx wrangler pages deploy dist --project-name otf-ui-native-storybook --commit-dirty=true",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@otf/ui-native": "workspace:*",
    "@otf/tokens": "workspace:*",
    "@tamagui/lucide-icons": "^1.144.4",
    "@tamagui/portal": "^1.144.4",
    "lucide-react-native": "^0.513.0",
    "expo": "~54.0.25",
    "expo-font": "~14.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.9",
    "expo-router": "~6.0.15",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "@expo/metro-runtime": "~6.1.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "@babel/runtime": "^7.25.0",
    "@react-native/normalize-colors": "0.81.5",
    "@react-navigation/native": "^7.1.20",
    "@react-navigation/bottom-tabs": "^7.5.6",
    "@react-navigation/native-stack": "^7.4.6",
    "expo-modules-core": "~3.0.30",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/bun": "^1.2.16",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  }
}
