{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@otf/ui": ["../../packages/ui/src/index.ts"],
      "@otf/tokens": ["../../packages/tokens/src/index.ts"]
    }
  },
  "include": ["stories/**/*", ".storybook/**/*"]
}
