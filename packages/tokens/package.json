{
  "name": "@otfdashkit/tokens",
  "version": "0.1.1",
  "description": "OTF design tokens — CSS variables (web) + Tamagui tokens (native). 17 themes, dark mode, parity across React + React Native.",
  "keywords": [
    "otfdashkit",
    "design-tokens",
    "css-variables",
    "tamagui",
    "tailwind",
    "design-system",
    "themes"
  ],
  "license": "MIT",
  "author": "otfdashkit <dave@otf-kit.dev>",
  "homepage": "https://github.com/otf-kit/sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/otf-kit/sdk.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/otf-kit/sdk/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./web.css": "./src/web.css"
  },
  "files": [
    "dist/**",
    "src/web.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tamagui/config": "^1.141.5",
    "@tamagui/core": "^1.141.5",
    "tailwindcss": "3",
    "tamagui": "^1.141.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@tamagui/core": ">=1.100.0",
    "tamagui": ">=1.100.0"
  },
  "peerDependenciesMeta": {
    "@tamagui/core": {
      "optional": true
    },
    "tamagui": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
